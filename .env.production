# Production environment variables
NODE_ENV=production
PORT=8080

# Database (use actual production URLs)
DATABASE_URL=
REDIS_URL=
MONGODB_URL=

# Authentication (MUST be changed in production)
JWT_SECRET=
JWT_EXPIRATION=3600
SESSION_SECRET=

# External APIs
API_BASE_URL=
FRONTEND_URL=

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Features
ENABLE_CACHE=true
ENABLE_RATE_LIMIT=true
ENABLE_METRICS=true

# Security
CORS_ORIGIN=
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=900000
