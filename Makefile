.PHONY: help build test clean install

help:
	@echo "make install - Install dependencies"
	@echo "make build   - Build services"
	@echo "make test    - Run tests"
	@echo "make clean   - Clean artifacts"

install:
	@echo "Installing..."

build:
	@echo "Building..."

test:
	@echo "Testing..."

clean:
	@echo "Cleaning..."
