root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{js,jsx,ts,tsx,json}]
indent_style = space
indent_size = 2

[*.{py}]
indent_style = space
indent_size = 4

[*.{rb}]
indent_style = space
indent_size = 2

[*.{go}]
indent_style = tab
indent_size = 4

[*.{rs}]
indent_style = space
indent_size = 4

[*.{java}]
indent_style = space
indent_size = 4

[*.{c,cpp,h,hpp}]
indent_style = space
indent_size = 4

[Makefile]
indent_style = tab
