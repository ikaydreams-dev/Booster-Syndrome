# Database
DATABASE_URL=postgresql://user:pass@localhost:5432/booster_db
REDIS_URL=redis://localhost:6379
MONGODB_URL=mongodb://localhost:27017/booster

# API Keys
API_SECRET_KEY=your-secret-key-here
JWT_SECRET=your-jwt-secret

# Services
PORT=3000
NODE_ENV=development

# Features
ENABLE_METRICS=true
ENABLE_LOGGING=true
